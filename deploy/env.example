# Drop in /etc/eve-trade-hub-analyzer/env, owned by eve-hub:eve-hub, mode 0600.
# Same shape as the dev .env.example; HUB_STRUCTURE_ID + HAUL_ISK_PER_M3 +
# TOKEN_ENCRYPTION_KEY are intentionally absent (ADDENDUM.md §1/§4).

DATABASE_URL=postgres://user:password@host:5432/eve_hub?sslmode=require

EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:5173/auth/callback
EVE_USER_AGENT=eve-trade-hub-analyzer/0.1.0 (you@example.com)

JITA_REGION_ID=10000002
POLL_INTERVAL_SECS=300

RUST_LOG=eve_trade_hub_analyzer=info,sqlx=warn
