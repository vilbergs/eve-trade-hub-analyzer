# Postgres connection. For managed hosts, include sslmode=require.
DATABASE_URL=postgres://eve:eve@localhost:5432/eve_hub?sslmode=disable

# EVE SSO app credentials (https://developers.eveonline.com)
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:5173/auth/callback

# Format: app/<version> (<contact email>)
EVE_USER_AGENT=eve-trade-hub-analyzer/0.1.0 (you@example.com)

# Optional, defaults shown
JITA_REGION_ID=10000002
POLL_INTERVAL_SECS=300

# Google Sheets exporter (optional — only needed for the `sheets` binary).
# 1. Create a service account in Google Cloud → IAM & Admin → Service Accounts,
#    grant it no project roles, download a JSON key.
# 2. Point GOOGLE_SERVICE_ACCOUNT_KEY_PATH at the JSON file.
# 3. Share the target spreadsheet with the service account's client_email
#    (Editor access).
# Scope used: https://www.googleapis.com/auth/spreadsheets
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
# Spreadsheet to push reports into. Each report becomes its own tab.
GOOGLE_SPREADSHEET_ID=

RUST_LOG=eve_trade_hub_analyzer=info,sqlx=warn
