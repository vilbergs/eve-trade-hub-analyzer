# Postgres connection. For managed hosts, include sslmode=require.
DATABASE_URL=postgres://eve:eve@localhost:5432/eve_hub?sslmode=disable

# EVE SSO app credentials (https://developers.eveonline.com)
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:5173/auth/callback

# Format: app/<version> (<contact email>)
EVE_USER_AGENT=eve-trade-hub-analyzer/0.1.0 (you@example.com)

# Generate once: `openssl rand -base64 32`
TOKEN_ENCRYPTION_KEY=

# Required once you've run `discover` and picked a structure
HUB_STRUCTURE_ID=

# Optional, defaults shown
HAUL_ISK_PER_M3=1000
JITA_REGION_ID=10000002
POLL_INTERVAL_SECS=300

RUST_LOG=eve_trade_hub_analyzer=info,sqlx=warn
